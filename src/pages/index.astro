---
import Layout from "../layouts/BaseLayout.astro";

const public_key = import.meta.env.PUBLIC_OMISE_PUBLIC_KEY;
---

<Layout title="Premium Omise Shop">
    <!-- Global Progress/Step Tracking -->
    <div id="checkout-progress" class="fixed top-0 left-0 w-full h-1 bg-primary/20 z-[120] overflow-hidden hidden">
        <div id="progress-bar" class="h-full bg-primary w-0 transition-all duration-500 shadow-[0_0_10px_#667eea]"></div>
    </div>

    <!-- Shipping Modal (Step 1) -->
    <div id="shipping-modal" class="fixed inset-0 bg-black/40 backdrop-blur-xl z-[100] hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-[40px] p-8 max-w-md w-full shadow-[0_32px_120px_rgba(0,0,0,0.2)] border border-white/20 transform translate-y-8 opacity-0" id="shipping-modal-inner">
            <button id="close-shipping-top" class="absolute top-6 right-6 p-2 bg-surface-secondary rounded-full text-text-secondary hover:text-text-primary transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
            <div class="flex items-center gap-3 mb-8">
                <div class="w-1.5 h-6 bg-primary rounded-full"></div>
                <h3 class="text-3xl font-black tracking-tight">Checkout</h3>
            </div>
            
            <div class="space-y-4" id="shipping-form">
                <div class="group relative">
                    <input type="text" id="ship-name" placeholder="Full Name" required class="w-full p-5 bg-surface-secondary rounded-3xl border-2 border-transparent focus:border-primary/30 focus:bg-white outline-none transition-all placeholder:text-text-secondary/50 font-medium" />
                </div>
                <div class="group relative">
                    <input type="email" id="ship-email" placeholder="Email Address" required class="w-full p-5 bg-surface-secondary rounded-3xl border-2 border-transparent focus:border-primary/30 focus:bg-white outline-none transition-all placeholder:text-text-secondary/50 font-medium" />
                </div>
                <div class="group relative">
                    <textarea id="ship-address" placeholder="Shipping Address & Zip" rows="3" required class="w-full p-5 bg-surface-secondary rounded-3xl border-2 border-transparent focus:border-primary/30 focus:bg-white outline-none transition-all resize-none placeholder:text-text-secondary/50 font-medium"></textarea>
                </div>
                <div class="group relative">
                    <input type="tel" id="ship-phone" placeholder="Phone Number" required class="w-full p-5 bg-surface-secondary rounded-3xl border-2 border-transparent focus:border-primary/30 focus:bg-white outline-none transition-all placeholder:text-text-secondary/50 font-medium" />
                </div>
                <button id="proceed-to-payment" class="w-full py-5 bg-primary text-white rounded-[24px] font-black text-xl hover:shadow-2xl hover:shadow-primary/40 transition-all active:scale-95 mt-6 flex items-center justify-center gap-2 group">
                    <span>Continue to Payment</span>
                    <svg class="group-hover:translate-x-1 transition-transform" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
                </button>
            </div>
            <p class="text-xs text-text-secondary/60 text-center mt-6">Step 1 of 2: Shipping & Contact</p>
        </div>
    </div>

    <!-- QR/Payment Modal (Step 2) -->
    <div id="qr-modal" class="fixed inset-0 bg-black/40 backdrop-blur-xl z-[110] hidden flex items-center justify-center p-4">
        <div class="bg-white rounded-[40px] p-8 max-w-sm w-full text-center shadow-[0_32px_120px_rgba(0,0,0,0.2)] border border-white/20 transform scale-90 opacity-0" id="qr-modal-inner">
            <button id="close-qr-top" class="absolute top-6 right-6 p-2 bg-surface-secondary rounded-full text-text-secondary">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
            </button>
            
            <div id="modal-content-paying" class="space-y-6">
                <div class="inline-flex items-center justify-center w-20 h-20 bg-primary/10 text-primary rounded-3xl animate-bounce">
                    <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path></svg>
                </div>
                <h3 class="text-3xl font-black">Scan to Pay</h3>
                <p class="text-text-secondary px-4 leading-relaxed font-medium">Almost there! ฿8,500 via PromptPay</p>
                
                <div id="qr-container" class="bg-white p-6 rounded-[32px] border-2 border-surface-secondary shadow-inner relative min-h-[240px] flex items-center justify-center">
                    <div class="animate-pulse flex flex-col items-center gap-3">
                        <div class="w-48 h-48 bg-surface-secondary rounded-3xl"></div>
                        <p class="text-xs font-bold uppercase tracking-widest text-primary">Generating QR Code...</p>
                    </div>
                </div>

                <div class="flex items-center justify-center gap-4 py-4 bg-surface-secondary/50 rounded-3xl">
                    <div class="relative w-3 h-3">
                        <div class="absolute inset-0 bg-primary rounded-full animate-ping opacity-75"></div>
                        <div class="relative bg-primary w-3 h-3 rounded-full"></div>
                    </div>
                    <span class="text-sm font-bold text-text-primary tracking-wide">Waiting for your scan...</span>
                </div>

                <button id="close-qr" class="text-sm font-bold text-text-secondary hover:text-red-500 transition-colors pt-2">Cancel Transaction</button>
            </div>

            <!-- Success State -->
            <div id="modal-content-success" class="hidden flex flex-col items-center">
                <div id="success-icon" class="w-24 h-24 bg-green-500 text-white rounded-[32px] flex items-center justify-center shadow-xl shadow-green-200 mb-8 opacity-0 scale-50">
                    <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>
                </div>
                <h3 class="text-4xl font-black mb-4">Order Confirmed</h3>
                <p class="text-text-secondary mb-10 text-lg leading-relaxed font-medium">Payment received. Your MK-Ultra keyboard is being prepared for shipping.</p>
                <button id="success-done" class="w-full py-5 bg-black text-white rounded-[24px] font-black text-xl hover:bg-gray-800 transition-all shadow-xl active:scale-95">Complete Order</button>
            </div>
        </div>
    </div>

	<main class="space-y-20 pb-20">
		<section class="flex justify-center flex-col items-center text-center space-y-8 container p-container-padding bg-surface-secondary h-[80vh] rounded-b-[64px] shadow-sm relative overflow-hidden">
            <div class="absolute top-0 right-0 w-96 h-96 bg-primary/10 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/2"></div>
			<div class="relative z-10">
                <h1 class="font-black tracking-tight text-text-primary mb-4 leading-[1.1]">Elite Precision <br/><span class="text-primary italic">Absolute Style</span></h1>
			    <p class="max-w-2xl text-xl text-text-secondary mx-auto">The ultimate typing experience, refined. Hand-lubed performance for those who demand more.</p>
			    <a href="#featured-product" class="mt-8 bg-black text-white py-5 px-12 rounded-full font-black text-lg transition-all hover:scale-105 hover:shadow-2xl hover:shadow-primary/20 inline-block shadow-lg">Purchase Now</a>
            </div>
		</section>

		<section id="featured-product" class="container p-container-padding -mt-32 relative z-20">
			<div class="grid grid-cols-1 md:grid-cols-2 gap-0 bg-white rounded-[48px] overflow-hidden shadow-[0_48px_140px_-40px_rgba(0,0,0,0.15)] border border-border/50 backdrop-blur-3xl">
				<div class="relative group overflow-hidden h-[400px] md:h-full cursor-zoom-in">
					<img src="/keyboard.png" alt="Keyboard" class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-125"/>
					<div class="absolute inset-0 bg-gradient-to-t from-black/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                    <div class="absolute bottom-6 left-6 text-white font-bold opacity-0 group-hover:opacity-100 translate-y-4 group-hover:translate-y-0 transition-all duration-500">65% Layout • Mechanical • Custom Switches</div>
				</div>
				
				<div class="p-10 lg:p-20 space-y-10 flex flex-col justify-center">
					<div class="space-y-2">
						<span class="inline-block py-1.5 px-4 bg-primary/10 text-primary font-bold tracking-widest uppercase text-xs rounded-full">Bestseller</span>
						<h2 class="text-5xl font-black tracking-tight">MK-Ultra Limited</h2>
                        <div class="flex items-center gap-3 pt-2">
						    <span class="text-4xl font-black text-text-primary">฿8,500</span>
						    <span class="text-text-secondary/60 line-through text-lg">฿12,000</span>
                            <span class="text-xs py-1 px-2 bg-green-100 text-green-600 font-extrabold rounded-lg">SAVE 30%</span>
					    </div>
					</div>
					
					<p class="text-text-secondary leading-relaxed text-xl font-medium">
						Optimized for tactile bliss. Solid CNC Aluminum, hot-swappable PCB, and double-shot keycaps designed for greatness.
					</p>

					<div class="grid grid-cols-2 gap-4 pb-4">
                        <div class="p-4 bg-surface-secondary rounded-3xl flex flex-col gap-1 border border-border/50">
                            <span class="text-[10px] font-black uppercase text-primary tracking-widest">Switches</span>
                            <span class="font-bold">Gateron Yellow</span>
                        </div>
                        <div class="p-4 bg-surface-secondary rounded-3xl flex flex-col gap-1 border border-border/50">
                            <span class="text-[10px] font-black uppercase text-primary tracking-widest">Connectivity</span>
                            <span class="font-bold">USB-C / 2.4G</span>
                        </div>
                    </div>

					<button id="buy-now-btn" class="w-full py-6 bg-primary text-white rounded-[28px] font-black text-2xl shadow-xl shadow-primary/30 hover:shadow-primary/50 hover:scale-[1.02] transition-all cursor-pointer flex items-center justify-center gap-3">
						<span>Get It Now</span>
                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"></path><path d="M3 6h18"></path><path d="M16 10a4 4 0 0 1-8 0"></path></svg>
					</button>
				</div>
			</div>
		</section>
	</main>
</Layout>

<script is:inline>
    // Global Accessors - Use ONLY GSAP for animations
    const getGSAP = () => window.gsap;

	const buyBtn = document.getElementById('buy-now-btn');
    const shippingModal = document.getElementById('shipping-modal');
    const qrModal = document.getElementById('qr-modal');
    const progressBar = document.getElementById('progress-bar');
    const progressContainer = document.getElementById('checkout-progress');

    let pollInterval = null;

    const openModal = (target, inner) => {
        const gsap = getGSAP();
        target.classList.remove('hidden');
        if(gsap) {
            gsap.to(inner, { y: 0, scale: 1, opacity: 1, duration: 0.6, ease: "expo.out" });
        }
    };

    const closeModal = (target, inner, complete) => {
        const gsap = getGSAP();
        if(!gsap) {
            target.classList.add('hidden');
            if(complete) complete();
            return;
        }
        gsap.to(inner, { y: 20, scale: 0.95, opacity: 0, duration: 0.4, ease: "power2.in",
            onComplete: () => {
                target.classList.add('hidden');
                if (complete) complete();
            }
        });
    };

    const shakeElement = (inner) => {
        const gsap = getGSAP();
        if(gsap) {
            gsap.to(inner, { x: [-15, 15, -15, 15, 0], duration: 0.4 });
        }
    };

    const celebrateSuccess = () => {
        console.log("Success view triggered.");
        document.getElementById('progress-bar').style.width = '100%';
        
        // Show success view
        document.getElementById('modal-content-paying').classList.add('hidden');
        document.getElementById('modal-content-success').classList.remove('hidden');

        const gsap = getGSAP();
        if(gsap) {
            gsap.to('#success-icon', { opacity: 1, scale: 1, duration: 0.8, ease: "elastic.out(1, 0.5)" });
        } else {
            document.getElementById('success-icon').style.opacity = '1';
        }
    };

    const startStatusCheck = (chargeId) => {
        if (pollInterval) clearInterval(pollInterval);
        pollInterval = setInterval(async () => {
            try {
                const response = await fetch(`/api/status?id=${chargeId}&t=${Date.now()}`);
                const data = await response.json();
                if (data.isSuccess === true) {
                    clearInterval(pollInterval);
                    celebrateSuccess();
                }
            } catch (err) { console.error(err); }
        }, 3000);
    };

	const initOmiseFlow = () => {
		if (typeof OmiseCard === 'undefined' || !document.body.dataset.pk) { 
            setTimeout(initOmiseFlow, 100); 
            return; 
        }

		OmiseCard.configure({
			publicKey: document.body.dataset.pk,
			buttonLabel: "Pay Now", currency: "thb", frameLabel: "Order MK-Ultra",
		});

		buyBtn.addEventListener('click', () => {
            openModal(shippingModal, '#shipping-modal-inner');
            progressContainer.classList.remove('hidden');
            progressBar.style.width = '30%';
        });

		document.getElementById('proceed-to-payment').addEventListener('click', (e) => {
			e.preventDefault();
            const inputs = ['ship-name', 'ship-email', 'ship-address', 'ship-phone'];
            const values = inputs.map(id => document.getElementById(id).value.trim());

            if (values.some(v => !v)) {
                shakeElement('#shipping-modal-inner');
                return;
            }

            closeModal(shippingModal, '#shipping-modal-inner', () => {
                progressBar.style.width = '60%';
                OmiseCard.open({
                    amount: 850000,
                    otherPaymentMethods: ["promptpay"], 
                    onCreateTokenSuccess: async (nonce) => {
                        progressBar.style.width = '80%';
                        let payload = { 
                            amount: 850000, 
                            email: values[1], 
                            metadata: { shipping_name: values[0], shipping_address: values[2], shipping_phone: values[3] } 
                        };
                        if (nonce.startsWith("tokn_")) payload.token = nonce; else payload.source = nonce;

                        try {
                            const res = await fetch('/api/checkout', { 
                                method: 'POST', 
                                headers: { 'Content-Type': 'application/json' }, 
                                body: JSON.stringify(payload) 
                            });
                            const result = await res.json();
                            if (res.ok) {
                                if (result.source && result.source.type === "promptpay") {
                                    document.getElementById('qr-container').innerHTML = `<img src="${result.source.scannable_code.image.download_uri}" alt="QR" class="mx-auto w-full max-w-[220px] rounded-2xl" />`;
                                    openModal(qrModal, '#qr-modal-inner');
                                    startStatusCheck(result.id);
                                } else { 
                                    celebrateSuccess(); 
                                    openModal(qrModal, '#qr-modal-inner'); 
                                }
                            } else { alert(result.error); }
                        } catch (err) { console.error(err); }
                    }
                });
            });
		});
	};

    // UI Listeners
    document.getElementById('close-shipping-top').onclick = () => { closeModal(shippingModal, '#shipping-modal-inner'); progressContainer.classList.add('hidden'); };
    document.getElementById('close-qr').onclick = () => { closeModal(qrModal, '#qr-modal-inner'); progressContainer.classList.add('hidden'); clearInterval(pollInterval); };
    document.getElementById('close-qr-top').onclick = () => { closeModal(qrModal, '#qr-modal-inner'); progressContainer.classList.add('hidden'); clearInterval(pollInterval); };
    document.getElementById('success-done').onclick = () => { window.location.reload(); };

    setTimeout(initOmiseFlow, 500);
</script>

<script is:inline define:vars={{ public_key }}>
    document.body.dataset.pk = public_key;
</script>